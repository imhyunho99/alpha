# 이 파일은 프로젝트에 필요한 환경 변수의 예시입니다.
# 이 파일을 복사하여 .env 파일을 만들고, 실제 값으로 채워주세요.
# .env 파일은 Git에 의해 추적되지 않습니다.

# QuestDB Configuration
DB_HOST=127.0.0.1
DB_PORT=8812
DB_NAME=qdb
DB_USER=admin
DB_PASSWORD=your_password_here

# 금융 데이터 API 제공업체 (예: Alpha Vantage, Finnhub)의 API 키
FINANCIAL_API_KEY=YOUR_API_KEY_HERE

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# --- v3.0 신규 설정 ---
# JWT 서명 키 (미설정 시 ~/AlphaModels/.jwt_secret 자동 생성). 운영 환경에선 반드시 지정.
ALPHA_JWT_SECRET=change-me-to-a-long-random-string
ALPHA_JWT_TTL_HOURS=12

# 최초 기동 시 사용자가 한 명도 없을 때 자동 생성될 admin 계정 비밀번호.
ALPHA_DEFAULT_ADMIN_PASSWORD=change-me-strong-password

# 브로커 선택: mock | alpaca
ALPHA_BROKER=mock
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# 위험 관리 정책 (선택)
ALPHA_RISK_MAX_POSITION_PCT=0.10
ALPHA_RISK_STOP_LOSS_PCT=0.07
ALPHA_RISK_TAKE_PROFIT_PCT=0.15
ALPHA_RISK_MAX_DAILY_BUYS=10
ALPHA_RISK_MAX_DAILY_LOSS_PCT=0.05
ALPHA_INITIAL_CASH=100000

# 클라이언트가 접속할 서버 URL
ALPHA_SERVER_URL=http://127.0.0.1:8000
