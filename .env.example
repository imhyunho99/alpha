# 이 파일은 프로젝트에 필요한 환경 변수의 예시입니다.
# 이 파일을 복사하여 .env 파일을 만들고, 실제 값으로 채워주세요.
# .env 파일은 Git에 의해 추적되지 않습니다.

# QuestDB Configuration
DB_HOST=127.0.0.1
DB_PORT=8812
DB_NAME=qdb
DB_USER=admin
DB_PASSWORD=your_password_here

# 금융 데이터 API 제공업체 (예: Alpha Vantage, Finnhub)의 API 키
FINANCIAL_API_KEY=YOUR_API_KEY_HERE

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
